# Trakt API application credentials
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret

# Plex server connection
PLEX_URL=http://your-plex-host:32400
PLEX_TOKEN=your_plex_token

# Optional runtime settings
DOCKER_MODE=false
TRAKTOR_WORKERS=8

# Watch sync settings (optional)
WATCH_SYNC_ENABLED=false
WATCH_SYNC_DIRECTION=both
WATCH_SYNC_CONFLICT_RESOLUTION=newest_wins

# Official Trakt curated lists (optional)
# These are Trakt's algorithmically generated lists based on aggregate user activity.
# They do NOT require OAuth - only your Client ID is needed.
#
# Available endpoints (comma-separated):
#
# MOVIES (7 endpoints):
#   movies.trending       - Currently being watched right now (updates frequently)
#   movies.popular        - Most popular movies overall
#   movies.played         - Most played (total play count)
#   movies.watched        - Most watched by unique users
#   movies.collected      - Most added to watchlists/collection
#   movies.anticipated    - Upcoming movies with most hype
#   movies.boxoffice      - Weekend box office performance (top 10)
#
# SHOWS (6 endpoints):
#   shows.trending        - Currently being watched right now
#   shows.popular         - Most popular shows overall
#   shows.played          - Most played episodes
#   shows.watched         - Most watched by unique users
#   shows.collected       - Most added to watchlists/collection
#   shows.anticipated     - Upcoming shows with most hype
#
# PERIOD-BASED ENDPOINTS (played/watched/collected):
#   These support time periods: daily, weekly, monthly, yearly
#   Default is 'weekly' - set with TRAKTOR_OFFICIAL_PERIOD
#
# RECOMMENDED COMBINATIONS:
#   Basic:           movies.trending,movies.popular,shows.trending,shows.popular
#   Popular:         movies.popular,shows.popular,movies.trending,shows.trending
#   Stats Weekly:    movies.played,movies.watched,shows.played,shows.watched
#   Stats Monthly:   movies.played,movies.watched,shows.played,shows.watched + TRAKTOR_OFFICIAL_PERIODS=monthly
#   Box Office:      movies.boxoffice,movies.trending
#   Full Set:        movies.trending,movies.popular,movies.played,movies.watched,movies.anticipated,movies.boxoffice,shows.trending,shows.popular,shows.played,shows.watched,shows.anticipated
#
TRAKTOR_OFFICIAL_LISTS_ENABLED=false
TRAKTOR_OFFICIAL_ENDPOINTS=movies.trending,movies.popular,shows.trending,shows.popular
TRAKTOR_OFFICIAL_PERIOD=weekly
# TRAKTOR_OFFICIAL_PERIODS=weekly,monthly  # For multiple period playlists

# Official lists cache TTLs (in hours, optional)
TRAKTOR_OFFICIAL_CACHE_TTL_TRENDING=1
TRAKTOR_OFFICIAL_CACHE_TTL_POPULAR=6
TRAKTOR_OFFICIAL_CACHE_TTL_PLAYED=6
TRAKTOR_OFFICIAL_CACHE_TTL_WATCHED=6
TRAKTOR_OFFICIAL_CACHE_TTL_COLLECTED=24
TRAKTOR_OFFICIAL_CACHE_TTL_ANTICIPATED=24
TRAKTOR_OFFICIAL_CACHE_TTL_BOXOFFICE=12
